{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "server/src/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "ml-service/main.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "server/src/index.js"
    },
    {
      "source": "/ml/(.*)",
      "destination": "ml-service/main.py"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "server/src/index.js"
    },
    {
      "source": "/dashboard/budgets",
      "destination": "/client/index.html"
    },
    {
      "source": "/dashboard/goals",
      "destination": "/client/index.html"
    },
    {
      "source": "/dashboard/insights",
      "destination": "/client/index.html"
    },
    {
      "source": "/dashboard/(.*)",
      "destination": "/client/index.html"
    },
    {
      "source": "/settings",
      "destination": "/client/index.html"
    },
    {
      "source": "/reports",
      "destination": "/client/index.html"
    },
    {
      "source": "/upload",
      "destination": "/client/index.html"
    },
    {
      "source": "/((?!api|ml|uploads|client).*)",
      "destination": "/client/$1"
    }
  ],
  "cleanUrls": true
}
