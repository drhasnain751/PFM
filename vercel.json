{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "server/src/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "ml-service/main.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "server/src/index.js"
    },
    {
      "source": "/ml/(.*)",
      "destination": "ml-service/main.py"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "server/src/index.js"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/client/assets/$1"
    },
    {
      "source": "/",
      "destination": "/client/index.html"
    },
    {
      "source": "/dashboard/(.*)",
      "destination": "/client/index.html"
    },
    {
      "source": "/(login|signup|features|about|contact|how-it-works)",
      "destination": "/client/index.html"
    },
    {
      "source": "/((?!api|ml|uploads|assets).*)",
      "destination": "/client/index.html"
    }
  ],
  "cleanUrls": true
}
