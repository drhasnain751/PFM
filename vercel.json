{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "server/src/index.js"
    },
    {
      "source": "/ml/(.*)",
      "destination": "ml-service/main.py"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "server/src/index.js"
    },
    {
      "source": "/((?!api|ml|uploads).*)",
      "destination": "/client/dist/index.html"
    }
  ],
  "cleanUrls": true
}
